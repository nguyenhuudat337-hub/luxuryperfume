<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_home"
    tools:context=".HomeFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/bannerSlider"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="100dp"
                android:layout_height="180dp"
                 />


            <LinearLayout
                android:id="@+id/layoutIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:text="Categories"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />


            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/c1"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/style_bar"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="Women"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/c2"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/style_bar"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="Man"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/c3"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/style_bar"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="Luxury"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/c4"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/style_bar"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="Sale"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/c5"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/style_bar"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="New"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

            </HorizontalScrollView>


            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:text="Best Sellers"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />


            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Item perfume -->
                    <LinearLayout
                        android:id="@+id/l1"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/perfume1" />



                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Dior Sauvage"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />

                            <ImageButton
                                android:id="@+id/btnFavoriteItem1"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/ic_favorite" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$120"
                            android:textColor="#FFD700" />
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/l2"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/perfume2" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Versace"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />

                            <ImageButton
                                android:id="@+id/btnFavoriteItem2"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/ic_favorite" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$200"
                            android:textColor="#FFD700" />
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/l3"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/perfume3" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Yves Saint Laurent"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />

                            <ImageButton
                                android:id="@+id/btnFavoriteItem3"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/ic_favorite" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$250"
                            android:textColor="#FFD700" />
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/l4"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/perfume4" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Bleu Chanel"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />

                            <ImageButton
                                android:id="@+id/btnFavoriteItem4"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/ic_favorite" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$215"
                            android:textColor="#FFD700" />
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/l5"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/perfume5" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tom Ford"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />

                            <ImageButton
                                android:id="@+id/btnFavoriteItem5"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/ic_favorite" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$300"
                            android:textColor="#FFD700" />
                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>


            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:text="All products"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>



        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/linearLayout4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="1dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="1dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/editTextText2"
            android:layout_width="320dp"
            android:layout_height="65dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/style_bar"
            android:drawableStart="@drawable/ic_search"
            android:ems="10"
            android:hint="search perfume"
            android:inputType="text"
            android:paddingStart="10dp" />

        <ImageButton
            android:id="@+id/imageButton6"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:background="@drawable/style_bar"
            app:srcCompat="@drawable/ic_notifi" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>